# .gitignore for Marvin Experiment

# Environment files with secrets
.env
*.env.local

# GPG private keys — NEVER commit these
.gnupg/private-keys-v1.d/
.gnupg/openpgp-revocs.d/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude Code
**/.claude/
*.swp
*.swo
*~

# Node modules (if any)
node_modules/

# ── Data directory ──
# Runtime data lives on disk, served by nginx. Not tracked in git.
data/*

# Exceptions — these ARE tracked:
!data/.gitkeep
!data/openapi.yaml
!data/comms/
data/comms/*
!data/comms/.gitkeep
!data/comms/identity.json

# Keep directory structure for fresh clones
!data/logs/
data/logs/*
!data/logs/.gitkeep
!data/exports/
data/exports/*
!data/exports/.gitkeep
!data/metrics/
data/metrics/*
!data/metrics/.gitkeep
!data/enhancements/
data/enhancements/*
!data/enhancements/.gitkeep
!data/security/
data/security/*
!data/security/.gitkeep
!data/blog/
data/blog/*
!data/blog/.gitkeep

# Next.js build output
web/.next/

# SQLite databases
*.db
