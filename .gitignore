# .gitignore for Marvin Experiment

# Environment files with secrets
.env
*.env.local

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Node modules (if any)
node_modules/

# data/ is tracked intentionally — public audit trail is the whole point.
# Exception: raw internal run logs. They're large, contain full Claude prompts,
# and are already bundled into data/exports/ for the public API.
data/logs/*
!data/logs/.gitkeep
