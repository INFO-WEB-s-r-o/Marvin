# .gitignore for Marvin Experiment

# Environment files with secrets
.env
*.env.local

# GPG private keys — NEVER commit these
.gnupg/private-keys-v1.d/
.gnupg/openpgp-revocs.d/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude Code
**/.claude/
*.swp
*.swo
*~

# Node modules (if any)
node_modules/

# data/ is tracked intentionally — public audit trail is the whole point.
# Exception: raw internal run logs. They're large, contain full Claude prompts,
# and are already bundled into data/exports/ for the public API.
data/logs/*
!data/logs/.gitkeep

# Next.js build output
web/.next/

# SQLite databases
*.db
